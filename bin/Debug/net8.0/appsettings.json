{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=booking_db;Username=postgres;Password=postgres"
  },
  "Consul": {
    "Host": "consul",
    "Port": 8500,
    "ServiceName": "booking-service",
    "ServicePort": 8082
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Exchanges": {
      "BookingExchange": "booking.exchange",
      "PaymentExchange": "payment.exchange",
      "MatchExchange": "match.exchange"
    },
    "Queues": {
      "BookingToPayment": "booking.to.payment.queue",
      "BookingToMatch": "booking.to.match.queue",
      "PaymentToBooking": "payment.to.booking.queue",
      "MatchToBooking": "match.to.booking.queue"
    },
    "RoutingKeys": {
      "PaymentRequest": "booking.payment.request",
      "MatchDelegate": "booking.match.delegate",
      "PaymentStatus": "payment.booking.status",
      "MatchPaid": "match.booking.paid"
    }
  },
  "Jwt": {
    "PublicKeyPath": "keys/rsaKey.public"
  }
}